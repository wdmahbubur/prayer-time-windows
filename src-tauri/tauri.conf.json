{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Prayer Times",
  "version": "0.1.8",
  "identifier": "co.tareq.prayertimes.windows",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev -- --port 5173",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Prayer Times",
        "width": 1020,
        "height": 760,
        "resizable": true,
        "center": true,
        "fullscreen": false
      },
      {
        "label": "widget",
        "title": "Prayer Widget",
        "url": "index.html?widget=true",
        "width": 320,
        "height": 118,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": false,
        "x": 32,
        "y": 96
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
