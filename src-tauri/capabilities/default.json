{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "widget"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "notification:default",
    "autostart:default",
    "store:default",
    "shell:allow-open",
    "updater:default"
  ]
}
